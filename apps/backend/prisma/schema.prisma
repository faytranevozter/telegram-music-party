// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Room {
    id        String   @id @unique
    chatId    String
    threadId  Int?
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    Queues   Queue[]
    Devices  Device[]
    Votes    Vote[]
    Feature Feature?

    @@unique([chatId, threadId])
}

model Device {
    id          String   @id @default(uuid())
    roomId      String
    room        Room     @relation(fields: [roomId], references: [id])
    name        String
    fingerprint String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model Queue {
    id        String    @id @default(uuid())
    roomId    String
    room      Room      @relation(fields: [roomId], references: [id])
    title     String
    url       String
    createdAt DateTime? @default(now())
    updatedAt DateTime  @updatedAt
}

model Vote {
    id        String   @id @default(uuid())
    roomId    String
    room      Room     @relation(fields: [roomId], references: [id])
    userId    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Feature {
    id                String   @id @default(uuid())
    roomId            String   @unique
    room              Room     @relation(fields: [roomId], references: [id])
    minimumVotes      Int      @default(5)
    nextCommand       Boolean  @default(false)
    nextOnlyAdmin     Boolean  @default(true)
    previousCommand   Boolean  @default(false)
    previousOnlyAdmin Boolean  @default(true)
    muteCommand       Boolean  @default(true)
    unmuteCommand     Boolean  @default(true)
    volumeCommand     Boolean  @default(false)
    maxQueueSize      Int      @default(25)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
}
